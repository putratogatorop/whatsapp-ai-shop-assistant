# --- App ---
APP_ENV=development
LOG_LEVEL=INFO
STORE_NAME=Toko Maju Jaya

# --- WhatsApp Cloud API (Meta for Developers > your app > WhatsApp > API Setup) ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Any string you make up — must match what you enter in the Meta webhook config UI
WHATSAPP_VERIFY_TOKEN=change-me
# App Dashboard > Settings > Basic > App Secret (used to verify webhook signatures)
WHATSAPP_APP_SECRET=
WHATSAPP_API_VERSION=v21.0

# --- LLM provider: groq | openai | anthropic | gemini ---
LLM_PROVIDER=groq
LLM_MODEL=
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# --- Database ---
# Set a real password for anything beyond local dev — docker-compose.yml
# reads POSTGRES_PASSWORD from this same .env to set up the Postgres container.
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/whatsapp_agent

# --- Redis (Celery broker/backend) ---
REDIS_URL=redis://redis:6379/0

# --- Vector DB ---
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=shop_knowledge_base

# --- Optional: n8n webhook for human-escalation notifications ---
N8N_WEBHOOK_URL=
